# Same password as the encrypted Vertretungs-PDFs (used only on the server by the cron job).
PLAN_PDF_PASSWORD=

# Neon: Dashboard → your project → Connection string (use the pooled "transaction" string for serverless if offered).
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_SUBJECT=mailto:admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Optional: origin users should open when tapping a notification (e.g. https://vertretungsplan.example.com)
PUBLIC_APP_URL=

# Protects GET /api/cron/check-plan-updates — send header: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
